# ─────────────────────────────────────────────────────────────────────────────
# Hybrid Search for Agents — environment configuration
#
# QUICK START: Copy this file to .env  (or just run: make setup)
# Everything below works out-of-the-box with Docker Compose.
# No edits required unless you want to customise behaviour.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Hybrid Search for Agents"
APP_VERSION="0.1.0"
DEBUG=false

# ── Search behaviour ──────────────────────────────────────────────────────────
MAX_SEARCH_RESULTS=5
MAX_CHARS_PER_PAGE=8000
FETCH_TIMEOUT_SECONDS=15
MAX_CONCURRENT_FETCHES=5
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=50
FETCH_BASE_URL="https://r.jina.ai"

# ── Brave Search fallback (optional) ──────────────────────────────────────────
# If DuckDuckGo gets throttled, the system falls back to Brave Search.
# Free tier: https://brave.com/search/api/  (2,000 queries/month free)
# Leave blank to use DDG only.
BRAVE_API_KEY=""

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Docker Compose maps port 5433 on your machine → 5432 inside the container.
# Keep this URL unchanged when using `make docker-up` or `make docker-up-full`.
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5433/hybriddb"
DATABASE_ECHO=false

# Connection pool — tune for your deployment size:
#   Dev / demo:    DB_POOL_SIZE=5,  DB_MAX_OVERFLOW=10
#   Staging:       DB_POOL_SIZE=10, DB_MAX_OVERFLOW=20  ← these defaults
#   Production:    DB_POOL_SIZE=20, DB_MAX_OVERFLOW=40
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
CACHE_TTL_SECONDS=3600   # 1 hour — set to 0 to disable caching

# ── Embeddings ────────────────────────────────────────────────────────────────
# USE_LOCAL_EMBEDDINGS=true  → BAAI/bge-small-en-v1.5 runs locally (no API key needed) ← recommended
# USE_LOCAL_EMBEDDINGS=false → OpenAI text-embedding-3-small (requires OPENAI_API_KEY)
USE_LOCAL_EMBEDDINGS=true

# Only needed when USE_LOCAL_EMBEDDINGS=false:
OPENAI_API_KEY=""
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS=1536

# ── API Authentication (optional) ─────────────────────────────────────────────
# REQUIRE_AUTH=false → all endpoints are public (fine for local use)
# REQUIRE_AUTH=true  → all endpoints except /health, /docs require X-API-Key header
REQUIRE_AUTH=false
API_KEYS=""   # Comma-separated list when auth is on, e.g. "key-abc,key-xyz"

# ── Deployment ────────────────────────────────────────────────────────────────
# Set to your public domain once deployed (used for Stripe redirect URLs)
APP_BASE_URL="http://localhost:8000"

# ── Stripe (Month 2 — hosted SaaS billing) ────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) during development, live keys in production.
# NEVER commit real keys — set these in Railway / Render environment variables.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""       # From Stripe dashboard → Webhooks
STRIPE_PUBLISHABLE_KEY=""

# Create products + prices in Stripe dashboard, paste the price_... IDs here:
STRIPE_PRICE_STARTER=""        # $29/mo
STRIPE_PRICE_PRO=""            # $99/mo
STRIPE_PRICE_TEAM=""           # $299/mo
STRIPE_PRICE_ENTERPRISE=""     # Custom (optional)
